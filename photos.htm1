<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>معرض صور ماجد عاطف</title>
    <style>
        body { background-color: #000; color: white; font-family: sans-serif; margin: 0; }
        .header { text-align: center; padding: 30px; border-bottom: 1px solid #262626; }
        .header img { width: 90px; height: 90px; border-radius: 50%; border: 2px solid #333; object-fit: cover; }
        .gallery {
            display: grid;
            grid-template-columns: repeat(3, 1fr); /* 3 صور بجانب بعض */
            gap: 3px; /* مسافة بسيطة جداً مثل إنستجرام */
            max-width: 800px;
            margin: 10px auto;
        }
        .gallery-item { aspect-ratio: 1 / 1; overflow: hidden; background-color: #111; }
        .gallery-item img { width: 100%; height: 100%; object-fit: cover; }
        
        /* للموبايل تظهر صورتين بجانب بعض لراحة العين */
        @media (max-width: 600px) { .gallery { grid-template-columns: repeat(2, 1fr); } }
    </style>
</head>
<body>
    <div class="header">
        <img src="15098.jpg" alt="Maged Atef">
        <h2>Maged Atef</h2>
        <p>اللحظات والذكريات ✨</p>
    </div>

    <div class="gallery">
        <div class="gallery-item"><img src="p1.jpg"></div>
        <div class="gallery-item"><img src="p2.jpg"></div>
        <div class="gallery-item"><img src="p3.jpg"></div>
        <div class="gallery-item"><img src="p4.jpg"></div>
        <div class="gallery-item"><img src="p5.jpg"></div>
        <div class="gallery-item"><img src="p6.jpg"></div>
    </div>
</body>
</html>
